# LLM (Azure OpenAI)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
LLM_PROVIDER=azure_openai

# Database — Python (agents/) uses SQLAlchemy + pyodbc and requires mssql+pyodbc:// format.
# The sqlserver:// format in the root .env is for Prisma/Next.js only and does not work with Python.
# Use 127.0.0.1 instead of localhost if you see connection issues.
# Example (replace YOUR_SA_PASSWORD and database name):
# DATABASE_URL="mssql+pyodbc://SA:YOUR_SA_PASSWORD@127.0.0.1:1433/talent_finder?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes"
DATABASE_URL=

# Tracing (LangSmith)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true

# Ingestion
JSEARCH_API_KEY=
# Comma-separated job-board URLs. If unset, scraper defaults to We Work Remotely (easier, 5–10 postings).
# Recommended (public, viewable postings):
#   USAJobs (use Search/Results with keyword): https://www.usajobs.gov/Search/Results?k=job&p=1
#   Set USAJOBS_SEARCH_KEYWORD to "internship", "part time", "software", etc. to search by term.
#   We Work Remotely: https://weworkremotely.com/categories/remote-programming-jobs
#   Remote.co:       https://remote.co/remote-jobs/developer/
#   Wellfound:       https://wellfound.com/jobs
SCRAPING_TARGETS=
# USAJobs search keyword (used when discovery URL is built automatically). Examples: job, internship, part time, software
USAJOBS_SEARCH_KEYWORD=job
INGESTION_SCHEDULE="0 2 * * *"

# Pipeline thresholds
SPAM_FLAG_THRESHOLD=0.7
SPAM_REJECT_THRESHOLD=0.9
SKILL_CONFIDENCE_THRESHOLD=0.75
BATCH_SIZE=100
